# Copy to .env and fill in.

# --- Postgres ---
# Neon (recommended): create a project at https://neon.tech and paste the
# pooled connection string here. Any standard Postgres TCP URL also works
# (local Postgres, `npx prisma dev`, etc.) — this app uses the node-postgres
# Prisma driver adapter.
DATABASE_URL="postgresql://user:password@host:5432/proplayturf?schema=public"

# --- Redis (Upstash) ---
# Only required when LEDGER_LOCK_DRIVER=redis. Create a database at
# https://upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Ledger lock ---
# "memory"  -> single-process async-mutex lock (dev/test; no Redis needed)
# "redis"   -> Upstash single-instance lock (production/multi-instance)
LEDGER_LOCK_DRIVER="memory"

# --- Firebase (Auth + Firestore members) ---
# Public web config from Firebase console -> Project settings -> Web app, or
# `firebase apps:sdkconfig WEB <appId>`. The apiKey is public (not a secret).
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""

# Server secret: base64 of the Admin SDK service-account JSON. NEVER commit.
# Firebase console -> Project settings -> Service accounts -> Generate new
# private key, then: `base64 -w0 serviceAccount.json`.
# Leave empty for offline dev — auth() falls back to the seeded demo player.
FIREBASE_SERVICE_ACCOUNT_KEY=""
